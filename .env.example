# Polymarket API (only needed for live trading, not simulation)
PM_API_KEY=
PM_SECRET=
PM_PASSPHRASE=

# Trading parameters
INITIAL_BALANCE=10000.0
MIN_ENTRY_PRICE=0.05
MIN_CONFIDENCE=0.60
# Don't take first position until this many seconds after first signal for that market (0 = allow first tick)
MIN_SECONDS_AFTER_MARKET_OPEN=30.0
# Direction + value: only YES when spot>=strike, only NO when spot<=strike (true = fewer but aligned trades)
REQUIRE_DIRECTIONAL_ALIGNMENT=true
# Momentum filter: YES only when price trend up over this many seconds, NO when down (0 = disabled)
MOMENTUM_LOOKBACK_SECONDS=0
SIMULATION_MODE=true

# Simulation tuning
SIM_LAG_MS=500
SIM_MARKET_INTERVAL_S=300
SIM_BTC_ANNUAL_VOL=0.70

# Kalshi (for live trading)
KALSHI_MODE=true
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY=
KALSHI_LIVE_EXECUTION=false
# Hard per-order dollar cap; set to e.g. 10 to cap at $10 per order (0 = no dollar cap)
KALSHI_LIVE_MAX_ORDER_USD=0
